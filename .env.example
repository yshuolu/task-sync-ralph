# ===========================================
# Lark TaskSync Daemon - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# Secrets MUST be set via env vars, never in config files.

# --- Required ---

# Lark app credentials (from Lark Developer Console)
LARK_APP_ID=
LARK_APP_SECRET=

# Comma-separated Lark tasklist GUIDs to sync
# Use `npx tsx src/cli.ts discover` to find available tasklist GUIDs
LARK_TASKLIST_GUIDS=

# --- Optional ---

# Lark domain: "lark" (international) or "feishu" (China mainland)
# Default: lark
# LARK_DOMAIN=lark

# Poll interval in milliseconds (default: 300000 = 5 minutes)
# TASKSYNC_POLL_INTERVAL_MS=300000

# Max parallel `claude -p` invocations (default: 1)
# TASKSYNC_PLAN_CONCURRENCY=1

# Per-plan timeout in milliseconds (default: 1800000 = 30 minutes)
# TASKSYNC_PLAN_TIMEOUT_MS=1800000

# Max retries per task before marking as failed (default: 3)
# TASKSYNC_PLAN_MAX_RETRIES=3

# Extra arguments for `claude -p` (default: empty)
# TASKSYNC_CLAUDE_ARGS=

# Path to flowctl binary (default: .flow/bin/flowctl)
# FLOWCTL_PATH=.flow/bin/flowctl
