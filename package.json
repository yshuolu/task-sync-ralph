{
  "name": "tasksync",
  "version": "0.1.0",
  "description": "A daemon that bridges Lark task management with flow-next epic planning",
  "type": "module",
  "main": "src/cli.ts",
  "scripts": {
    "discover": "tsx src/cli.ts discover",
    "start": "tsx src/cli.ts start",
    "status": "tsx src/cli.ts status",
    "stop": "tsx src/cli.ts stop",
    "sync-once": "tsx src/cli.ts sync-once",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx/esm --test tests/**/*.test.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.40.0",
    "p-queue": "^9.1.0",
    "proper-lockfile": "^4.1.2",
    "write-file-atomic": "^7.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/write-file-atomic": "^4.0.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
